# Canvas ESPM Scraper — Environment Variables
# =============================================
# Copy this file to .env and fill in your credentials.

# ESPM login credentials (the academic email + password)
ESPM_PORTAL_LOGIN=seu.email@acad.espm.br
ESPM_PORTAL_PASSWORD=sua_senha_aqui

# Download directory (default: ./downloads)
DOWNLOAD_DIR=./downloads

# Run headless? (default: true)
# Set to "false" to see the browser window during execution
HEADLESS=true
