{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CoffeeMindMap",
  "description": "Schema for mind map generated by GPT-4o-mini from lecture summaries. Backend saves as JSONB in gravacoes.mind_map. iOS renders with deterministic layout.",
  "type": "object",
  "required": ["topic", "branches"],
  "properties": {
    "topic": {
      "type": "string",
      "description": "Central theme of the lecture. Max 30 characters.",
      "maxLength": 30
    },
    "branches": {
      "type": "array",
      "description": "Main concept groups. Always exactly 4 branches.",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["topic", "color", "children"],
        "properties": {
          "topic": {
            "type": "string",
            "description": "Branch label. Max 20 characters.",
            "maxLength": 20
          },
          "color": {
            "type": "integer",
            "description": "Color index 0-3 mapping to palette: 0=red, 1=orange, 2=green, 3=purple.",
            "minimum": 0,
            "maximum": 3
          },
          "children": {
            "type": "array",
            "description": "Subtopics under this branch. Always exactly 3 children.",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "string",
              "description": "Leaf node text. Max 22 characters.",
              "maxLength": 22
            }
          }
        }
      }
    }
  }
}
