{
  "description": "Addition to Coffee API Contract v2 — mind_map field in gravacao responses",
  
  "affected_endpoints": [
    "GET /gravacoes/{id}",
    "GET /gravacoes (list)",
    "POST /gravacoes (response after processing)"
  ],

  "field_addition": {
    "field": "mind_map",
    "type": "object | null",
    "nullable": true,
    "description": "Auto-generated mind map. NULL while processing or if generation failed. Present when status=ready.",
    "schema": {
      "topic": "string (max 30 chars) — central theme",
      "branches": [
        {
          "topic": "string (max 20 chars) — branch label",
          "color": "int 0-3 — palette index",
          "children": ["string (max 22 chars)", "string", "string"]
        }
      ]
    }
  },

  "example_gravacao_detail_response": {
    "data": {
      "id": "uuid",
      "source_type": "disciplina",
      "source_id": "uuid",
      "date": "2026-02-25",
      "date_label": "Terça, 25 de fevereiro",
      "duration_seconds": 4800,
      "duration_label": "1h 20min",
      "status": "ready",
      "short_summary": "A aula abordou o mix de marketing...",
      "full_summary": [{"title": "...", "bullets": ["..."]}],
      "transcription": "Bom dia a todos...",
      "mind_map": {
        "topic": "Mix de Marketing",
        "branches": [
          {"topic": "Produto", "color": 0, "children": ["Qualidade e Design", "Ciclo de Vida", "Marca e Embalagem"]},
          {"topic": "Preço", "color": 1, "children": ["Precificação", "Elasticidade", "Preço Psicológico"]},
          {"topic": "Praça", "color": 2, "children": ["Canais de Distrib.", "Logística", "E-commerce"]},
          {"topic": "Promoção", "color": 3, "children": ["Publicidade", "Marketing Digital", "Relações Públicas"]}
        ]
      },
      "media": [],
      "materials": [],
      "created_at": "2026-03-06T..."
    }
  },

  "ios_behavior": {
    "when_null": "Hide mind map tab/section in gravacao detail screen",
    "when_processing": "Show skeleton/loading state",
    "when_ready": "Render with deterministic SwiftUI layout using ios_layout_constants.json"
  }
}
